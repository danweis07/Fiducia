# Digital Banking Platform — Environment Variables
# Copy this file to .env.local and fill in values

# =============================================================================
# DATABASE (Supabase) - Required
# =============================================================================
# Your Supabase project URL (get from Supabase Dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon (public) key
VITE_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# MAPPING - Required for ATM/branch locator
# =============================================================================
VITE_MAPLIBRE_STYLE_URL=https://demotiles.maplibre.org/style.json

# =============================================================================
# ERROR MONITORING (Sentry) - Optional
# =============================================================================
VITE_SENTRY_DSN=
VITE_APP_ENV=development
VITE_APP_VERSION=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable demo mode (sample data fallback when Supabase is unavailable)
VITE_DEMO_MODE=false

# =============================================================================
# INTEGRATION ADAPTERS — Sandbox Configuration
# =============================================================================
# All integrations fall back to mock adapters when no credentials are set.
# See docs/SANDBOX-INTEGRATIONS.md for full setup instructions.

# -----------------------------------------------------------------------------
# Apache Fineract (Core Banking) — Open source, self-hosted
# Docker: docker run -p 8443:8443 apache/fineract:latest
# -----------------------------------------------------------------------------
# FINERACT_BASE_URL=https://localhost:8443/fineract-provider/api/v1
# FINERACT_TENANT_ID=default
# FINERACT_USERNAME=mifos
# FINERACT_PASSWORD=password

# -----------------------------------------------------------------------------
# Symitar SymXchange (Core Banking) — Jack Henry, 800+ credit unions
# SOAP/XML API with token-based auth. Requires network access to the
# SymXchange endpoint (typically on-prem or VPN).
# Sets provider for: core_banking
# -----------------------------------------------------------------------------
# SYMITAR_HOST=symxchange.example.com
# SYMITAR_PORT=443
# SYMITAR_USER_NUMBER=1
# SYMITAR_PASSWORD=your_password
# SYMITAR_DEVICE_TYPE=CLIENTSYSTEM
# SYMITAR_DEVICE_NUMBER=20000

# -----------------------------------------------------------------------------
# CU*Answers CU*BASE (Core Banking, KYC, RDC, Account Opening)
# For credit unions on the CU*Answers/CU*BASE core platform (200+ CUs).
# QA docs: https://api-qa.cuanswers.com/docs/
# Sets provider for: core_banking, kyc, rdc, account_opening
# -----------------------------------------------------------------------------
# CUANSWERS_BASE_URL=https://api-qa.cuanswers.com/api
# CUANSWERS_APP_KEY=your_app_key
# CUANSWERS_CREDIT_UNION_ID=CUXXXXX

# -----------------------------------------------------------------------------
# Plaid (External Account Linking) — Free sandbox at dashboard.plaid.com
# -----------------------------------------------------------------------------
# PLAID_CLIENT_ID=your_client_id
# PLAID_SECRET=your_sandbox_secret
# PLAID_ENV=sandbox

# -----------------------------------------------------------------------------
# MX (Financial Data & Transaction Enrichment) — Developer portal at mx.com
# Auth: HTTP Basic with MX_CLIENT_ID:MX_API_KEY
# -----------------------------------------------------------------------------
# MX_API_KEY=your_api_key
# MX_CLIENT_ID=your_client_id
# MX_BASE_URL=https://int-api.mx.com

# -----------------------------------------------------------------------------
# Alloy (KYC/Identity Verification) — Sandbox by request at alloy.com
# Auth: HTTP Basic with ALLOY_API_KEY:ALLOY_SECRET
# -----------------------------------------------------------------------------
# ALLOY_API_KEY=your_sandbox_key
# ALLOY_SECRET=your_sandbox_secret
# ALLOY_BASE_URL=https://sandbox.alloy.co/v1

# -----------------------------------------------------------------------------
# AI Services — Set one or more API keys; auto-detected by the adapter
# -----------------------------------------------------------------------------
# GOOGLE_AI_API_KEY=your_key     # Preferred — free tier via AI Studio
# OPENAI_API_KEY=your_key        # GPT models
# ANTHROPIC_API_KEY=your_key     # Claude models

# =============================================================================
# AI PLATFORM — RAG & Knowledge Base
# =============================================================================
# Vector store for RAG retrieval (pgvector is built into Supabase)
# No additional config needed if using Supabase — pgvector is auto-enabled
# PINECONE_API_KEY=your_key          # Optional: use Pinecone instead of pgvector
# PINECONE_ENVIRONMENT=us-east-1

# =============================================================================
# WEBHOOKS — Event Delivery
# =============================================================================
# WEBHOOK_SIGNING_SECRET=whsec_your_signing_secret
# WEBHOOK_RETRY_ATTEMPTS=3

# =============================================================================
# DATA EXPORT
# =============================================================================
# S3-compatible storage for data exports (optional — falls back to Supabase Storage)
# EXPORT_S3_BUCKET=your-bucket
# EXPORT_S3_REGION=us-east-1
# EXPORT_S3_ACCESS_KEY=your_key
# EXPORT_S3_SECRET_KEY=your_secret

# =============================================================================
# TWILIO (SMS) + SENDGRID (Email) — Transactional notifications
# =============================================================================
# Free Twilio test credentials at https://www.twilio.com/console
# SendGrid free tier: 100 emails/day at https://signup.sendgrid.com/
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+15551234567
# SENDGRID_API_KEY=your_sendgrid_key
# SENDGRID_FROM_EMAIL=noreply@yourcu.com
# SENDGRID_FROM_NAME=Your Credit Union

# =============================================================================
# WIRE TRANSFERS
# =============================================================================
# WIRE_PROVIDER=mock                   # mock | fedwire | swift

# --- FedWire (Domestic) ---
# Access via FedLine Developer: https://www.frbservices.org/fedline-solutions/fedline-developer
# ISO 20022 (pacs.008) since July 2025
# FEDWIRE_BASE_URL=
# FEDWIRE_API_KEY=
# FEDWIRE_ROUTING_NUMBER=
# FEDWIRE_INSTITUTION_NAME=

# --- SWIFT gpi (International) ---
# Free sandbox at https://developer.swift.com
# OAuth 2.0 + JWT-Bearer grant. Demo: https://github.com/swiftinc/gpi-v5-demo-app
# SWIFT_BASE_URL=https://sandbox.swift.com
# SWIFT_API_KEY=
# SWIFT_CONSUMER_KEY=
# SWIFT_CONSUMER_SECRET=
# SWIFT_BIC=

# =============================================================================
# P2P / ZELLE
# =============================================================================
# ZELLE_API_KEY=your_key
# ZELLE_PARTNER_ID=your_partner_id

# =============================================================================
# CONSENT MANAGEMENT — Privacy & Cookie Consent
# =============================================================================
# Choose a consent provider: built-in | ketch | osano | onetrust
# Default: built-in (custom React cookie banner)
VITE_CONSENT_PROVIDER=built-in

# --- Ketch (Developer-friendly, API-first privacy orchestration) ---
# VITE_KETCH_ORG_CODE=your_org_code
# VITE_KETCH_PROPERTY_CODE=your_property_code

# --- Osano (Simple, no-nonsense compliance) ---
# VITE_OSANO_CUSTOMER_ID=your_customer_id
# VITE_OSANO_CONFIG_ID=your_config_id

# --- OneTrust (Enterprise-grade, widely trusted by legal teams) ---
# VITE_ONETRUST_DOMAIN_SCRIPT=your-uuid-domain-script
# VITE_ONETRUST_AUTO_BLOCK=true
