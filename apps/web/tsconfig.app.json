{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020",
    "useDefineForClassFields": true
  },
  "include": ["src"],
  "exclude": [
    "src/components/__tests__/ai-escalation.test.ts",
    "src/components/__tests__/ai-insights-engine.test.ts",
    "src/components/__tests__/ai-prompts.test.ts",
    "src/components/__tests__/ai-rag-retrieval.test.ts",
    "src/components/__tests__/ai-rules-engine.test.ts"
  ]
}
