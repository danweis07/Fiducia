# Match (code signing) configuration
# See: https://docs.fastlane.tools/actions/match/
#
# SETUP: Create a private git repo for certificates, then update git_url below.
# Run `fastlane match init` to configure.

git_url(ENV["MATCH_GIT_URL"] || "https://github.com/YOUR_ORG/ios-certificates.git")

storage_mode("git")

type("appstore")

app_identifier(ENV["APP_IDENTIFIER"] || "com.example.digitalbanking")

team_id(ENV["TEAM_ID"] || "XXXXXXXXXX")
