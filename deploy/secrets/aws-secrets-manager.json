{
  "_comment": [
    "AWS Secrets Manager — Reference configuration for the Digital Banking Platform.",
    "Create the secret: aws secretsmanager create-secret --name banking-platform/production --secret-string file://secrets.json",
    "The ECS task definition or Lambda config references this secret ARN.",
    "For CloudFormation, see deploy/aws/cloudformation.yaml."
  ],
  "secretName": "banking-platform/${ENVIRONMENT}",
  "description": "Digital Banking Platform secrets (Supabase, core banking, integrations)",
  "rotationRules": {
    "automaticallyAfterDays": 90
  },
  "tags": [
    { "Key": "Project", "Value": "digital-banking-platform" },
    { "Key": "ManagedBy", "Value": "infra-as-code" }
  ],
  "secretStructure": {
    "VITE_SUPABASE_URL": "https://xxx.supabase.co",
    "VITE_SUPABASE_ANON_KEY": "eyJ...",
    "SUPABASE_SERVICE_ROLE_KEY": "eyJ...",
    "SUPABASE_JWT_SECRET": "your-jwt-secret",
    "FINERACT_BASE_URL": "https://fineract.example.com:8443/fineract-provider/api/v1",
    "FINERACT_PASSWORD": "",
    "SYMITAR_HOST": "",
    "SYMITAR_PASSWORD": "",
    "PLAID_CLIENT_ID": "",
    "PLAID_SECRET": "",
    "MX_API_KEY": "",
    "MX_CLIENT_ID": "",
    "ALLOY_API_KEY": "",
    "ALLOY_SECRET": "",
    "WEBHOOK_SIGNING_SECRET": ""
  }
}
