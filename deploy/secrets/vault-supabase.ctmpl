{{/* Vault Consul Template — renders Supabase edge function secrets as JSON */}}
{{- with secret "secret/data/banking-platform/production" -}}
{
  "supabase_url": "{{ .Data.data.VITE_SUPABASE_URL }}",
  "supabase_service_role_key": "{{ .Data.data.SUPABASE_SERVICE_ROLE_KEY }}",
  "jwt_secret": "{{ .Data.data.SUPABASE_JWT_SECRET }}"
}
{{ end }}
