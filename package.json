{
  "name": "fiducia",
  "private": true,
  "version": "1.0.0",
  "description": "Multi-tenant digital banking platform — monorepo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danweis07/Fiducia.git"
  },
  "homepage": "https://github.com/danweis07/Fiducia#readme",
  "bugs": {
    "url": "https://github.com/danweis07/Fiducia/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "core-simulator"
  ],
  "scripts": {
    "dev": "npm run dev -w @fiducia/web",
    "build": "npm run build -w @fiducia/web",
    "typecheck": "npm run typecheck -w @fiducia/web",
    "lint": "npm run lint -w @fiducia/web",
    "lint:fix": "npm run lint:fix -w @fiducia/web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run validate -w @fiducia/web",
    "test": "npm run test -w @fiducia/web",
    "test:run": "npm run test:run -w @fiducia/web",
    "test:coverage": "npm run test:coverage -w @fiducia/web",
    "test:e2e": "npm run test:e2e -w @fiducia/web",
    "i18n:check": "npm run i18n:check -w @fiducia/web",
    "i18n:types": "npm run i18n:types -w @fiducia/web",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  }
}
