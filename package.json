{
  "name": "fiducia",
  "private": true,
  "version": "1.4.3",
  "description": "Multi-tenant digital banking platform — monorepo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danweis07/Fiducia.git"
  },
  "homepage": "https://github.com/danweis07/Fiducia#readme",
  "bugs": {
    "url": "https://github.com/danweis07/Fiducia/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "core-simulator"
  ],
  "config": {
    "webWorkspace": "@fiducia/web"
  },
  "scripts": {
    "dev": "npm run dev -w $npm_package_config_webWorkspace",
    "build": "npm run build -w $npm_package_config_webWorkspace",
    "typecheck": "npm run typecheck -w $npm_package_config_webWorkspace",
    "lint": "npm run lint -w $npm_package_config_webWorkspace",
    "lint:fix": "npm run lint:fix -w $npm_package_config_webWorkspace",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run validate -w $npm_package_config_webWorkspace",
    "test": "npm run test -w $npm_package_config_webWorkspace",
    "test:run": "npm run test:run -w $npm_package_config_webWorkspace",
    "test:coverage": "npm run test:coverage -w $npm_package_config_webWorkspace",
    "test:e2e": "npm run test:e2e -w $npm_package_config_webWorkspace",
    "i18n:check": "npm run i18n:check -w $npm_package_config_webWorkspace",
    "i18n:types": "npm run i18n:types -w $npm_package_config_webWorkspace",
    "migrate": "npx tsx scripts/migrate.ts",
    "migrate:status": "npx tsx scripts/migrate.ts --status",
    "migrate:dry-run": "npx tsx scripts/migrate.ts --dry-run",
    "prepare": "husky"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "next-themes": "^0.4.6",
    "vite": "^6.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  }
}
